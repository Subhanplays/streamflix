# Leave NEXT_PUBLIC_API_URL unset so the app uses same-origin /api (Next.js proxies to Express).
# Only set it if you must call the API from a different host/port.
# NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Where Next.js should forward /api (must match server PORT, default 5000)
API_PROXY_TARGET=http://127.0.0.1:5000

NEXT_IGNORE_INCORRECT_LOCKFILE=1
